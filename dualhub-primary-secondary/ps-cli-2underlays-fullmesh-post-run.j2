    set dstaddr "all"
     set srcaddr "all"
    set schedule "always"
    set service "ALL"
    set logtraffic disable
        set comment "for initial testing only"
  next
end
config firewall local-in-policy
edit "1"
set dstaddr "all"
set service "ALL"
set schedule "always"
set intf "any"
set internet-service-src enable
set internet-service-src-name "Malicious-Malicious.Server" "Tor-Exit.Node" "Tor-Relay.Node"

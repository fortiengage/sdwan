{# ------------------------------- #}

      config neighbor
     end
  end
end

{# Hub sdwan template tuning #}
{# Currently FMG SOT doesn't fully support SD-WAN template on hub,
    - doesn't config zone
    - doesn't config underlay interface in members
    This script is to workaround it and support SD-WAN template on Hub.
#}
config adom/wanprof/sdwan-hub
  config system sdwan
      set status enable
      set option sdwan-overlay
      set load-balance-mode source-dest-ip-based
      config zone
          {% for k in range(data.number_of_hubs_underlay) %}
          edit "WAN{{k+1}}"
            set service-sla-tie-break fib-best-match
            next
          {% endfor %}
        edit "OVERLAYS"
          set service-sla-tie-break fib-best-match
        next
      end
      config members
          {% for k in range(data.number_of_hubs_underlay) %}
          edit {{k+1}}
            set interface "$(isp_intf_name_{{k+1}})" {#{data.hub_underlay_name[0][k]}#}
            set gateway "$(isp_intf_gateway_{{k+1}})"
            set zone "WAN{{k+1}}"
          next
          {% endfor %}
          {% for j in range(data.number_of_hubs_underlay) %}
          edit {{data.number_of_hubs_underlay+j+1}}
            set interface "VPN{{j+1}}"
            set zone "OVERLAYS"
          next
          {% endfor %}
      end
      config health-check
      end
  end
end

{% set ns = namespace(hub_sdwan_interface_name = "") %}
{% if overlay_variables.hub_sdwan_template | default('') == 'enable' %}
config adom/template/_router_static/{{data.sd_wan_overlay_name}}_HUB_Router
config router static
edit 100
set distance 1
{% for i in range(data.number_of_hubs_underlay) %}
{% set ns.hub_sdwan_interface_name = ns.hub_sdwan_interface_name ~ ' "WAN' ~ (i + 1) ~ '"' %}
{% endfor %}
set sdwan-zone {{ns.hub_sdwan_interface_name}}
set _seq-num 100
next
end
{% endif %}

config service
edit 1
set name "TO-HUB1-ROUTE-TAG1-LOAD-BALANCE"
set mode sla
set dst "ROUTE_TAG_1"
set src "all"
set priority-members 3 4
set tie-break fib-best-match
set load-balance enable
config sla
edit "HUB1_VPN1"
set id 1
next
edit "HUB1_VPN2"
set id 1
next
end
next


edit 2
set name "TO-HUB2-ROUTE-TAG2-LOAD-BALANCE"
set mode sla
set dst "ROUTE_TAG_2"
set src "all"
set priority-members 5 6
set tie-break fib-best-match
set load-balance enable
config sla
edit "HUB2_VPN1"
set id 1
next
edit "HUB2_VPN2"
set id 1
next
end
next

edit 100
set name "BRANCH-TO-BRANCH-ROUTE_TAG100"
set mode sla
set dst "ROUTE_TAG_100"
set src "all"
set priority-members 3 4 5 6
set tie-break fib-best-match

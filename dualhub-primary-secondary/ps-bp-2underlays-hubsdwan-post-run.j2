{#
  This script includes all the best practices from the PS team when they deploy SD-WAN projects for customers. 
  IPsec
  BGP
  SD-WAN

  It will need the following data from the device and the overlay template CSV: 
  - number of hubs
  - number of underlays
  - as_id from the overlay template, {{overlay_variables.as_id}}


#}


config fmg variable
edit "ipsec_psk"
set type password
set value "CHANGEME_CHANGEME"
next
end


{# 2060323 #}
{#
config fmg variable
edit "lan_intf"
  config dynamic_mapping
  {% for device in device_data %}
  edit "{{device.Name}}"-"global"
  set value "{{device.lan_intf[0].name}}"
  next
  {% endfor %}
  end
next
end
#}


config fmg variable
  edit "lan_intf"
    set value "port1"
    config dynamic_mapping
      {% for device in device_data %}
        {% if device.hub_branch == "Hub" %}
      edit "{{device.Name}}"-"global"
      set value "{{device.lan_intf[0].name}}"
      next
      edit "{{device.Name}}"-"root"
      set value "{{device.lan_intf[0].name}}"
      next
        {% endif %}
      {% endfor %}
    end
  next
  edit "HA_Cluster_Name"
    set value "HA_Cluster_Name"
  next
  edit "Name"
    set value "Name"
  next
  edit "branch_id"
    set value "1000"
  next
  edit "branch_wan1"
    set value "wan1"
  next
  edit "branch_wan2"
    set value "wan2"
  next
  edit "isp_intf_gateway_1"
    set value "0.0.0.0"
  next
  edit "isp_intf_gateway_2"
    set value "0.0.0.0"
  next
  edit "isp_intf_name_1"
    set value "wan1"
  next
  edit "isp_intf_name_2"
    set value "wan2"
  next
end


{# IPsec 
    [number of hubs] x [number of underlays] = number of phase1-interface/phase2-interface
    The naming convention is "HUBx-VPNx". 
    The following is the example.
#}
{#IPsec_Branch_Group#}
{% for i in range(data.number_of_branch_groups) %}
{% if i == 0 %}
config adom/template/_ipsec/{{data.sd_wan_overlay_name}}_BRANCH_IPsec
{% else %}
config adom/template/_ipsec/{{data.sd_wan_overlay_name}}_BRANCH{{i+1}}_IPsec
{% endif %}
    {% for j in range(data.number_of_hubs) %}
        {% for k in range(data.number_of_hubs_underlay) %}
        config vpn ipsec phase1-interface
            edit "HUB{{j+1}}-VPN{{k+1}}"
                set interface "$(isp_intf_name_{{k+1}})"
                set dpd-retrycount 3
                set dpd-retryinterval 3
                set exchange-fgt-device-id enable
                set dhgrp 14 20 21
                set auto-discovery-shortcuts dependent
                set idle-timeoutinterval 5
                set keylife 14400
                set psksecret "$(ipsec_psk)"
            next
        end
        config vpn ipsec phase2-interface
            edit "HUB{{j+1}}-VPN{{k+1}}"
                set dhgrp 14
                set replay disable
                set keylifeseconds 7200
            next
        end
        {% endfor %}
    {% endfor %}
end
{% endfor %}
 
{#IPsec_Hub#}
{% for i in range(data.number_of_hubs) %}
config adom/template/_ipsec/{{data.sd_wan_overlay_name}}_HUB{{i+1}}_IPsec
    {% for j in range(data.number_of_hubs_underlay) %}
    config vpn ipsec phase1-interface
        edit "VPN{{j+1}}"
            set interface "{{data.hub_underlay_name[i][j]}}"
            set dpd-retrycount 3
            set dpd-retryinterval 3
            set exchange-fgt-device-id enable
            set dhgrp 14 20 21
            set keylife 28800
            set psksecret "$(ipsec_psk)"
        next
    end
    config vpn ipsec phase2-interface
        edit "VPN{{j+1}}"
            set dhgrp 14
            set replay disable
            set keylifeseconds 14400
            set keepalive enable
        next
    end
    {% endfor %}
end
{% endfor %}
 
{#BGP_Branch_Group#}
{% for i in range(data.number_of_branch_groups) %}
{% if i == 0 %}
config adom/template/router_bgp/{{data.sd_wan_overlay_name}}_BRANCH_BGP
{% else %}
config adom/template/router_bgp/{{data.sd_wan_overlay_name}}_BRANCH{{i+1}}_BGP
{% endif %}
    config router bgp
        set keepalive-timer 10
        set holdtime-timer 30
        config neighbor
        {% for j in range(data.number_of_hubs) %}
            edit "{{data.hubs_hardcoded_ip_in_bgp_template[j]}}"
                set capability-dynamic enable
                set advertisement-interval 2
                set next-hop-self enable
                set connect-timer 2
                set route-map-out RTMAP_OUT
                unset route-map-out-preferable
                set interface "Branch-Lo"
                set update-source "Branch-Lo"
                set route-map-in RTMAP_IN_HUB{{j+1}}
                next
        {% endfor %}
        end
        
        {# It needs to check if the dynamic BGP is enabled here. Only if dynamic BGP is enabled, the neighbor-group will be shown in BGP template. 
           check overlay_variables.dynamic_bgp = 'YES', then modify the neighbor-group.
           James is going to add the overlay varaibles and device data to the beginning of this script when install it to FMG. 
        config neighbor-group
            edit "DYN_EDGE"
                set capability-graceful-restart enable
                set capability-dynamic enable
                set advertisement-interval 2
                set connect-timer 2
                set route-map-in RTMAP_IN_DYN_BGP
                set route-map-out RTMAP_OUT
                unset prefix-list-out
            next
        end
        #}
         
         {#  added by Remi March 17 #}
          
          config neighbor-group
            edit "DYN_EDGE"
                set capability-graceful-restart disable
                set capability-dynamic enable
                set advertisement-interval 2
                set connect-timer 2
                set route-map-in RTMAP_IN_DYN_BGP
                set route-map-out RTMAP_OUT
                unset prefix-list-out
            next
        end
        
        {# ------------------- #}
         
         
        config network
            edit 1
              set prefix-name "lan-subnet-grp"
            next
        end

    end
end
{% endfor %}
 
{#BGP_HUB#}

{# 20260323 Olesya #}

{% set hubs = device_data | selectattr('hub_branch', 'equalto', 'Hub') | list %}

{% for hub in hubs %}
config adom/template/router_bgp/{{data.sd_wan_overlay_name}}_HUB{{loop.index}}_BGP
    config router bgp
        set keepalive-timer 10
        set holdtime-timer 30

        config aggregate-address
            edit 1
                set prefix {{ overlay_variables.loopback_ip }} {{ overlay_variables.loopback_network_mask }}
                set summary-only enable
            next
        end

        config neighbor-group
            edit "EDGE"
                set capability-dynamic enable
                set advertisement-interval 2
                set connect-timer 2
                set route-map-in RTMAP_IN_ALL_OVERLAYS
                set route-map-out RTMAP_OUT_ALL_OVERLAYS
            next
        end

{% if hub.network_advertisement.network_prefix | length > 0 %}
        config network
            edit 1
                set prefix-name "lan-subnet-grp"
            next
            edit 100
               set prefix-name SDWAN_Loopback
            next
        end

{% else %}

        config network
            purge
        end
        config network
            edit 100
               set prefix-name SDWAN_Loopback
            next
        end
        
{% endif %}

    end
end
{% endfor %}

{# Branch sdwan template tuning #}
config adom/wanprof/sdwan-branch
  config system sdwan
      set status enable
      set option sdwan-overlay
      set load-balance-mode source-dest-ip-based
      config zone
      end
      {# Currently, FMG doesn't support add gateway to the underlay members when the member interface is in static mode.
         This script is to set interface and gateway correctly for each of the branch. 
      #}
      config members
      
      {# added by Remi for WAN underlays #}
       
          {% for k in range(data.number_of_hubs_underlay) %}
          edit {{k+1}}
            set interface "$(isp_intf_name_{{k+1}})" {#{data.hub_underlay_name[0][k]}#}
            set gateway "$(isp_intf_gateway_{{k+1}})"
            set zone "WAN{{k+1}}"
          next
          {% endfor %}
          end
              
      
 {#  added by Remi March 17h  #} 
    {# we assume their all Internet underlays = transport-group 1 #}
     
config members
edit 3
set interface "HUB1-VPN1"
set priority-in-sla 5
set priority-out-sla 10
set transport-group 1
next
edit 4
set interface "HUB1-VPN2"
set priority-in-sla 5
set priority-out-sla 10
set transport-group 1     
next
edit 5
set interface "HUB2-VPN1"
set priority-in-sla 5
set priority-out-sla 10
set transport-group 1     
next
edit 6
set interface "HUB2-VPN2"
set priority-in-sla 5
set priority-out-sla 10
set transport-group 1     
next
end
       
config health-check
